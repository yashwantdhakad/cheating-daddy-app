# Copy this file to .env and fill in the keys you use.
# .env is gitignored - NEVER commit real keys.
#
# Keys set here override keys entered in the app UI (which are stored
# encrypted in the OS keychain-backed credentials store, not in this repo).

# Gemini (BYOK transcription + screenshot answers) - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (answers + Groq Whisper transcription) - https://console.groq.com/keys
GROQ_API_KEY=

# Claude (optional premium answers) - https://platform.claude.com/
ANTHROPIC_API_KEY=

# OpenAI (optional) - https://platform.openai.com/
OPENAI_API_KEY=
